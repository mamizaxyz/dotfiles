#!/bin/sh

wmpid()
{
	tree="$(pstree -ps $$)"
	tree="${tree#*$WM(}"
	echo "${tree%%)*}"
}

case "$(printf "Exit\nрџ”’ Lockdown\nрџљЄ Leave $WM\nрџЄџ Restart $WM\nрџ’¤ Suspend\nрџђ» Hibernate\nрџ”ѓ Reboot\nрџ’» Shutdown\nрџ“є Display off\nвЏ° Uptime" | rofi -dmenu -i -p "Action: ")" in
	"Exit") exit;;
	"рџ”’ Lockdown") notify-send "Locking down" && sleep 2 && slock;;
	"рџљЄ Leave $WM") kill -TERM "$(wmpid)";;
	"рџЄџ Restart $WM") kill -HUP "$(wmpid)";;
	"рџ’¤ Suspend") slock systemctl suspend -i;;
	"рџђ» Hibernate") slock systemctl hibernate -i;;
	"рџ”ѓ Reboot") notify-send "Rebooting the system" && sleep 2 && reboot;;
	"рџ’» Shutdown") notify-send "Going down" && sleep 2 && shutdown -h now;;
	"рџ“є Display off") xset dpms force off;;
	"вЏ° Uptime") notify-send "$(uptime -p)" ;;
	*) exit 1;;
esac
